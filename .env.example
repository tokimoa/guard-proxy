# =================================================================
# Guard Proxy - 環境設定
# =================================================================

# -----------------------------------------------------------------
# アプリケーション設定
# -----------------------------------------------------------------
APP_NAME=Guard Proxy
DEBUG=false
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FORMAT=text

# -----------------------------------------------------------------
# プロキシ設定
# -----------------------------------------------------------------
NPM_PROXY_PORT=4873
NPM_UPSTREAM_URL=https://registry.npmjs.org
PYPI_PROXY_PORT=4874
PYPI_UPSTREAM_URL=https://pypi.org
RUBYGEMS_PROXY_PORT=4875
RUBYGEMS_UPSTREAM_URL=https://rubygems.org
GO_PROXY_PORT=4876
GO_UPSTREAM_URL=https://proxy.golang.org
ADMIN_API_PORT=8100

# -----------------------------------------------------------------
# クールダウンゲート設定
# -----------------------------------------------------------------
COOLDOWN_DAYS=7
COOLDOWN_ACTION=warn

# -----------------------------------------------------------------
# 静的解析設定
# -----------------------------------------------------------------
STATIC_ANALYSIS_ENABLED=true
STATIC_ANALYSIS_SEVERITY_THRESHOLD=medium

# -----------------------------------------------------------------
# LLM Judge 設定 (共通)
# -----------------------------------------------------------------
LLM_ENABLED=false
# 実行戦略: local_first (推奨) | cloud_only | local_only | consensus
LLM_STRATEGY=local_first
LLM_MAX_TOKENS=4096
LLM_MAX_FILE_SIZE_KB=512

# -----------------------------------------------------------------
# エスカレーション設定
# -----------------------------------------------------------------
# ローカルLLMのconfidenceがこの値未満ならクラウドにエスカレーション
LOCAL_CONFIDENCE_THRESHOLD=0.8
# 難読化スコアがこの値以上ならローカルをスキップしてクラウドに直接送信
OBFUSCATION_CLOUD_THRESHOLD=0.7

# -----------------------------------------------------------------
# ローカルLLM (Ollama) 設定
# -----------------------------------------------------------------
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
# 推奨: qwen3.5:9b (デフォルト), gemma4:26b, qwen3-coder:30b, mistral-small3.2:24b
# 事前に ollama pull <model> が必要
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_TIMEOUT_SECONDS=60

# -----------------------------------------------------------------
# クラウドLLM - Anthropic (プライマリ) 設定
# -----------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_TIMEOUT_SECONDS=30

# -----------------------------------------------------------------
# クラウドLLM - OpenAI (フォールバック) 設定
# -----------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_TIMEOUT_SECONDS=30

# -----------------------------------------------------------------
# クラウドLLM - OpenAI互換 (カスタム) 設定
# vLLM等のカスタムサーバーを使用する場合
# -----------------------------------------------------------------
# CUSTOM_LLM_BASE_URL=http://vllm-server:8000/v1
# CUSTOM_LLM_API_KEY=
# CUSTOM_LLM_MODEL=

# -----------------------------------------------------------------
# コスト制御
# -----------------------------------------------------------------
CLOUD_DAILY_LIMIT=100
CLOUD_MONTHLY_BUDGET_USD=20.0

# -----------------------------------------------------------------
# 判定エンジン設定
# -----------------------------------------------------------------
DECISION_MODE=warn
WARN_THRESHOLD=0.3
DENY_THRESHOLD=0.7
COOLDOWN_WEIGHT=0.3
STATIC_ANALYSIS_WEIGHT=0.4
LLM_WEIGHT=0.3

# -----------------------------------------------------------------
# キャッシュ設定
# -----------------------------------------------------------------
CACHE_DB_PATH=./data/cache.db
CACHE_TTL_HOURS=168
CACHE_MAX_SIZE_MB=500

# -----------------------------------------------------------------
# データベース設定
# -----------------------------------------------------------------
DB_PATH=./data/guard_proxy.db

# -----------------------------------------------------------------
# 通知設定
# -----------------------------------------------------------------
SLACK_WEBHOOK_URL=

# -----------------------------------------------------------------
# スキャナー有効化設定
# -----------------------------------------------------------------
TYPOSQUATTING_ENABLED=true
HEURISTICS_ENABLED=true
AST_ANALYSIS_ENABLED=true
REACHABILITY_ENABLED=true
YARA_ENABLED=true
YARA_RULES_PATH=
# コミュニティルールソースのURL (JSON配列)
# 例: YARA_RULE_SOURCES=["https://raw.githubusercontent.com/.../rules.yar"]
YARA_RULE_SOURCES=[]
# 起動時に自動更新するかどうか
YARA_AUTO_UPDATE=false
SBOM_ENABLED=true
MAINTAINER_CHECK_ENABLED=true
DEPENDENCY_CHECK_ENABLED=true
DEPSDEV_TIMEOUT=2.0

# -----------------------------------------------------------------
# ライセンスコンプライアンス設定
# -----------------------------------------------------------------
LICENSE_CHECK_ENABLED=false
# 拒否するライセンスのリスト (SPDX ID, カンマ区切り)
# 例: LICENSE_DENIED_LIST=["GPL-3.0-only","AGPL-3.0-only"]
LICENSE_DENIED_LIST=[]
# 許可するライセンスのリスト (設定時はリスト外が全て警告/拒否)
# 例: LICENSE_ALLOWED_LIST=["MIT","Apache-2.0","BSD-3-Clause","ISC"]
LICENSE_ALLOWED_LIST=[]
# ライセンス違反時のアクション: warn | deny
LICENSE_CHECK_ACTION=warn
# コピーレフトライセンスの扱い: allow | warn | deny
LICENSE_COPYLEFT_ACTION=allow

# -----------------------------------------------------------------
# アドバイザリ同期設定
# -----------------------------------------------------------------
ADVISORY_SYNC_ENABLED=true
ADVISORY_SYNC_INTERVAL_HOURS=6
